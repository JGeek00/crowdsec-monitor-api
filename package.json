{
  "name": "crowdsec-monitor-api",
  "version": "1.14.0-beta.2",
  "description": "REST API server for CrowdSec LAPI",
  "license": "MIT",
  "author": "JGeek00",
  "repository": {
    "type": "git",
    "url": "https://github.com/JGeek00/crowdsec-monitor-api.git"
  },
  "type": "commonjs",
  "main": "dist/server.js",
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon",
    "dev:no-nodemon": "ts-node -r tsconfig-paths/register src/server.ts",
    "build:dev": "tsc && tsc-alias",
    "bump-version:major": "node scripts/bump-version.js major",
    "bump-version:major:beta": "node scripts/bump-version.js major beta",
    "bump-version:minor": "node scripts/bump-version.js minor",
    "bump-version:minor:beta": "node scripts/bump-version.js minor beta",
    "bump-version:bugfix": "node scripts/bump-version.js bugfix",
    "bump-version:bugfix:beta": "node scripts/bump-version.js bugfix beta",
    "bump-version:beta": "node scripts/bump-version.js beta",
    "build:prod": "pnpm run build:prod:compile && pnpm run build:prod:obfuscate",
    "build:prod:compile": "tsc --sourceMap false --declaration false --declarationMap false && tsc-alias",
    "build:prod:obfuscate": "node scripts/obfuscate.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "test": "vitest run",
    "test:unit": "vitest run src/utils src/validators src/constants src/helpers src/services src/config",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:integration": "vitest run src/controllers src/routes src/middlewares src/app.ts",
    "test:e2e": "vitest run src/sockets src/__tests__/e2e-* src/__tests__/app.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "1.18.1",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "express-validator": "7.3.2",
    "helmet": "8.2.0",
    "morgan": "1.11.0",
    "pg": "8.22.0",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.8",
    "sqlite3": "6.0.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.9.4",
    "@types/supertest": "^6.0.3",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitest/coverage-v8": "^3.2.7",
    "ajv": "^8.20.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "javascript-obfuscator": "5.4.3",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "supertest": "^7.2.2",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.17",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^3.2.7"
  }
}
