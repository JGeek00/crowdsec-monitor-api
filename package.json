{
  "name": "crowdsec-monitor-api",
  "version": "1.9.0-beta.9",
  "description": "REST API server for CrowdSec LAPI",
  "license": "MIT",
  "author": "JGeek00",
  "repository": {
    "type": "git",
    "url": "https://github.com/JGeek00/crowdsec-monitor-api.git"
  },
  "type": "commonjs",
  "main": "dist/server.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon",
    "build:dev": "tsc && tsc-alias",
    "bump-version:major": "node scripts/bump-version.js major",
    "bump-version:major:beta": "node scripts/bump-version.js major beta",
    "bump-version:minor": "node scripts/bump-version.js minor",
    "bump-version:minor:beta": "node scripts/bump-version.js minor beta",
    "bump-version:bugfix": "node scripts/bump-version.js bugfix",
    "bump-version:bugfix:beta": "node scripts/bump-version.js bugfix beta",
    "bump-version:beta": "node scripts/bump-version.js beta",
    "build:prod": "pnpm run build:prod:compile && pnpm run build:prod:obfuscate",
    "build:prod:compile": "tsc --sourceMap false --declaration false --declarationMap false && tsc-alias",
    "build:prod:obfuscate": "node scripts/obfuscate.js"
  },
  "dependencies": {
    "axios": "1.14.0",
    "cors": "2.8.6",
    "dotenv": "17.4.0",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "express-validator": "7.3.2",
    "helmet": "8.1.0",
    "morgan": "1.10.1",
    "pg": "8.20.0",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.8",
    "sqlite3": "6.0.1",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.5.0",
    "@types/ws": "8.18.1",
    "javascript-obfuscator": "5.4.1",
    "nodemon": "3.1.14",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
