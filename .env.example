# Server Configuration
PORT=3000
NODE_ENV=development

# CrowdSec LAPI Configuration
CROWDSEC_LAPI_URL=http://localhost:8080
CROWDSEC_USER=your_machine_id_here
CROWDSEC_PASSWORD=your_password_here
CROWDSEC_BOUNCER_KEY=your_bouncer_key_here (to read existing decisions)

# Database Configuration
DB_MODE=sqlite # Options: sqlite, postgres

DB_PATH=./database/crowdsec.db

# Postgres
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Data Retention (optional - auto-delete old data)
# Format: <number><unit> where unit is d (days), w (weeks), m (months), y (years)
# Examples: 1d, 3w, 2m, 1y
# If not set, data is retained indefinitely
DATA_RETENTION=

# Sync Configuration
# Interval in seconds between data synchronization
# Examples: 10 (every 10 seconds), 30 (every 30 seconds), 300 (every 5 minutes)
# Default: 30 seconds if not set
SYNC_INTERVAL_SECONDS=

# Blocklist IPs ban duration
# Format: <number><unit> where unit is s (seconds), m (minutes), h (hours), d (days)
# Examples: 1h (1 hour), 24h (24 hours), 7d (7 days)
BLOCKLIST_IPS_BAN_DURATION=

# Blocklists Refresh Time (optional)
# Interval in seconds to refresh the list of IPs of every added blocklist
# Examples: 3600 (every hour), 86400 (every day)
BLOCKLISTS_REFRESH_TIME=


# Blocklists Sync Time (optional)
# Interval in seconds to sync the list of alerts generated by the blocklists with the local database and disable the blocklists that have been deleted from CrowdSec
# Examples: 3600 (every hour), 86400 (every day)
BLOCKLISTS_SYNC_TIME=


# CrowdSec managed blocklists refresh time (optional)
# Interval in seconds to sync with the local database the list of blocklists managed by CrowdSec
# Examples: 3600 (every hour), 86400 (every day)
CROWDSEC_BLOCKLISTS_REFRESH_TIME=

# API Authentication (optional)
# If set, API endpoints will require Bearer token authentication
# Send as: Authorization: Bearer <API_PASSWORD>
# Leave empty to disable authentication
API_PASSWORD=

# Optional, format: <requests>/<minutes>, leave empty to disable rate limiting
RATE_LIMIT=
